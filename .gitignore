.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*~
.cursor/

# Node / build artifacts (none in this plugin currently, but future-proofing)
node_modules/
dist/
build/
*.log

# Python (in case anyone adds tooling for the deliverable rendering)
